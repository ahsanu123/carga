	(text "Program Fast-Charge Safety Timer (TMR):\nRTMR = tMAXCHG / (10 × KTMR )\nKTMR = 48 s/kΩ from the electrical characteristics table.\nRTMR = (6.25 hr × 3600 s/hr) / (10 × 48 s/kΩ) = 46.8 kΩ ->  46.4 kΩ\n"
		(exclude_from_sim no)
		(at 214.63 -205.994 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "4ba0c95b-29ca-493d-980f-a4f23af578d0")
	)
	(text "3 Wire to Force+ \n2/4 Wire to GND\nConnect 2_Wire if use 2/4 Wire"
		(exclude_from_sim no)
		(at 244.602 -135.382 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "543ae0ad-77e1-425b-9e87-342094ece3d9")
	)
	(text "Program the Fast Charge Current (ISET):\nRISET = KISET / ICHG\nKISET = 890 AΩ from the electrical characteristics table.\nRISET = 890 AΩ / 0.8 A = 1.1125 kΩ -> 1.13 kΩ"
		(exclude_from_sim no)
		(at 214.376 -197.358 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "5f316fea-7aac-4c01-9680-dd73ea02eb51")
	)
	(text "miso - Also known as q, this is the input of the serial stream into the ESP32\nmosi - Also known as d, this is the output of the serial stream from the ESP32\nsclk - Clock signal. Each data bit is clocked out or in on the positive or negative edge of this signal\nquadwp - Write Protect signal. Only used for 4-bit (qio/qout) transactions.\nquadhd - Hold signal. Only used for 4-bit (qio/qout) transactions."
		(exclude_from_sim no)
		(at -1.778 -101.6 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "79d21b42-d07a-4725-bd76-065131afd6ad")
	)
